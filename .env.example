# ─────────────────────────────────────────────────────────────
# Zenect Solutions — environment configuration
# Copy to `.env.local` for local dev; set the same keys in Vercel.
# All values are public (NEXT_PUBLIC_*) because the site talks to
# Supabase directly from the browser under Row Level Security.
# ─────────────────────────────────────────────────────────────

# Supabase project URL (Project Settings → API → Project URL)
NEXT_PUBLIC_STORE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (Project Settings → API → anon public)
NEXT_PUBLIC_STORE_KEY=your-anon-public-key

# Passphrase that unlocks the /console admin area (client-side gate)
NEXT_PUBLIC_CONSOLE_KEY=choose-a-strong-passphrase

# Canonical site origin — used for metadata, OpenGraph, canonical URLs
NEXT_PUBLIC_SITE_ORIGIN=https://zenectsolutionsllc.com
